# Postavka Assistant Bot — пример конфига.
# Скопируй в .env и заполни. Никогда не коммить .env с реальными секретами.

# ── Telegram (обязательно) ────────────────────────────────────────────────

# Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=

# Твой Telegram user_id — получит /admin_stats и legacy fallback кредов.
# Узнать: написать @userinfobot. Можно поставить 0 чтобы выключить admin-команды.
ALLOWED_USER_ID=0

# ── Шифрование пользовательских токенов (КРИТИЧНО на проде) ──────────────

# Fernet master-key. Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Без ключа — токены пишутся PLAIN TEXT (ок для dev, опасно на проде).
# При смене ключа все ранее сохранённые токены становятся нечитаемыми.
TOKEN_ENCRYPTION_KEY=

# ── Legacy single-tenant fallback (опционально) ──────────────────────────

# Если задано — используется как fallback для ALLOWED_USER_ID,
# когда у него нет своих ключей в БД. Полезно при миграции с single-tenant.
# Новые юзеры этими ключами НЕ пользуются.
APIKEY_OZON=
CLIEN_TID=
APIKEY_WB=

# ── LLM-парсер (опционально) ──────────────────────────────────────────────
# Используется для разбора xlsx с экзотической структурой.
APIKEY_CLAUDE=

# ── Прокси для Ozon API (опционально, общий на всех юзеров) ──────────────
# socks5://user:pass@host:port  или  http://user:pass@host:port
# Если у Ozon возникают блокировки на IP сервера — заведи SOCKS5 в РФ.
OZON_PROXY_URL=

# ── Имя поставщика (для ТЗ Отгрузки) ─────────────────────────────────────
# Подставляется в шапку xlsx ТЗ. Можно переопределить per-user через БД.
SUPPLIER_NAME=ИП Баковец
